    "details": {
      "id": 2,
      "fullDescription": [
        {
          "type": "paragraph",
          "children": [
            {
              "type": "text",
              "text": "<p>Process Modelling and Optimisation in MATLAB provides a systematic, application-oriented introduction to developing mathematical models of chemical and engineering processes and improving their performance through optimisation techniques.</p><p>The workshop focuses on translating real-world process systems into equations based on mass and energy balances, kinetics, and transport phenomena.</p><ul><li>Hands-on exercises in MATLAB for steady-state and dynamic analysis</li><li>Formulating objective functions for process improvement</li><li>Simulating behavior under varying operating conditions</li></ul><p>The session is led by <strong>Dr Virivinti Nagajyothi</strong>, specializing in stochastic optimisation and process control.</p>"
            }
          ]
        }
      ],
      "price": "Rs. 200/-",
      "capacity": 1,
      "organizer": "Dr. Virivinti Nagajyothi (NIT Tiruchirappalli)",
      "website": null
    }
